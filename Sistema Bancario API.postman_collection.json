{
  "info": {
    "_postman_id": "9a846f5b-7cd3-44a2-89e3-102c6aeb6aa1",
    "name": "Sistema Bancario API",
    "description": "Collection profissional e completa para testes de integracao do Sistema Bancario API (Laravel 11). Inclui scripts de automacao para captura de tokens e cenarios de erro reais (ACID / HTTP 422).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52625259"
  },
  "item": [
    {
      "name": "1. Autenticacao",
      "item": [
        {
          "name": "Registar Novo Cliente (Sucesso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set(\"token\", jsonData.token);",
                  "        console.log(\"Token de Autenticacao capturado automaticamente!\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Afonso Shelby\",\n    \"email\": \"afonso@email.com\",\n    \"password\": \"password123\",\n    \"nif\": \"123456789\",\n    \"birth_date\": \"1999-01-01\",\n    \"pin_code\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            },
            "description": "Cria um novo utilizador no sistema com validacao de NIF, encriptacao de password e PIN, e injeta o token automaticamente nas variaveis da collection."
          },
          "response": []
        },
        {
          "name": "Efetuar Login (Obter Novo Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set(\"token\", jsonData.token);",
                  "        console.log(\"Novo Token de Autenticacao atualizado!\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"afonso@email.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Autentica um utilizador existente e atualiza a variavel de sessao global do Bearer Token."
          },
          "response": []
        }
      ],
      "description": "Endpoints relacionados com o registo, controlo de acessos e geracao de chaves criptograficas de sessao (Laravel Sanctum)."
    },
    {
      "name": "2. Gestao de Contas",
      "item": [
        {
          "name": "Abrir Nova Conta Bancaria",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts"
              ]
            },
            "description": "Cria uma conta bancaria vinculada ao titular autenticado. Gera automaticamente o formato de IBAN PT50 protegido contra duplicados."
          },
          "response": []
        },
        {
          "name": "Consultar Saldo Atual",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/1/balance",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "balance"
              ]
            },
            "description": "Retorna o saldo atual com auditoria de seguranca (Bloqueia acessos de terceiros com HTTP 403 Forbidden)."
          },
          "response": []
        }
      ],
      "description": "Abertura e monitorizacao de balancos monetarios com suporte a multi-titularidade futura."
    },
    {
      "name": "3. Operacoes Financeiras (Movimentos)",
