              "raw": "{\n    \"amount\": 1250.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/1/deposit",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "deposit"
              ]
            },
            "description": "Injeta dinheiro na conta especificada. Valida se o montante e estritamente positivo."
          },
          "response": []
        },
        {
          "name": "Levantamento (Sucesso)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 200.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/1/withdraw",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "withdraw"
              ]
            },
            "description": "Efetua a subtracao de capital caso o saldo seja maior ou igual ao montante requisitado."
          },
          "response": []
        },
        {
          "name": "Levantamento (Erro - Saldo Insuficiente 422)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 9999999.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/1/withdraw",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "withdraw"
              ]
            },
            "description": "Cenario obrigatorio do enunciado. Demonstra a blindagem do saldo rejeitando operacoes ilicitas com o codigo HTTP 422 Unprocessable Entity."
          },
          "response": []
        },
        {
          "name": "Transferencia Atomica (Entre Contas)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"source_account_id\": 1,\n    \"destination_account_id\": 2,\n    \"amount\": 150.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transfers"
              ]
            },
            "description": "Realiza uma movimentacao segura entre duas entidades distintas (ACID Compliance). Se uma das pontas falhar, ocorre Rollback automatico."
          },
          "response": []
        }
      ],
      "description": "Modulo transacional do motor financeiro. Responsavel pela mutacao de saldos e escrita no Livro Razao."
    },
    {
      "name": "4. Extratos e Auditorias",
      "item": [
        {
          "name": "Histórico Completo (Cursor Paginado)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/1/transactions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "transactions"
              ]
            },
            "description": "Exigencia avancada do professor. Usa paginacao por ponteiro de cursor imune a degradacao de performance por tabelas massivas."
          },
          "response": []
        },
        {
          "name": "Extrato Filtrado (Dinâmico)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/1/statement?type=DEPOSIT&start_date=2026-01-01&end_date=2026-12-31",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts",
                "1",
                "statement"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "DEPOSIT",
                  "description": "Filtro opcional: DEPOSIT, WITHDRAWAL, TRANSFER_OUT, TRANSFER_IN"
                },
                {
                  "key": "start_date",
                  "value": "2026-01-01",
                  "description": "Data inicial (AAAA-MM-DD)"
                },
                {
                  "key": "end_date",
                  "value": "2026-12-31",
                  "description": "Data limite (AAAA-MM-DD)"
                }
              ]
            },
            "description": "Permite ao cliente pesquisar por movimentos especificos num intervalo temporal definido."
          },
          "response": []
        }
      ],
      "description": "Endpoints analiticos focados em performance e transparência contabilistica."
    },
